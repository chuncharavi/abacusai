# -----------------------------------------------
# AbacusAI — DigitalOcean Environment Variables
# Copy this to .env and fill in your values
# -----------------------------------------------

# PostgreSQL password (choose a strong random password)
POSTGRES_PASSWORD=change_me_to_a_strong_password

# JWT secret — any long random string (min 32 chars)
SESSION_SECRET=change_me_to_a_long_random_secret_string

# Anthropic Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Razorpay payment keys (leave blank to disable payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
